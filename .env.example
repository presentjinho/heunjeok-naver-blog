# 실제 값은 이 파일이나 Git에 기록하지 마세요. 배포 서비스의 Secret 저장소에 넣습니다.
APP_ORIGIN=https://your-app.example
PORT=3000
NODE_ENV=production
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=https://your-app.example/api/v1/auth/naver/callback
NAVER_DATALAB_CLIENT_ID=
NAVER_DATALAB_CLIENT_SECRET=
SEARCHAD_ENABLED=false
SEARCHAD_API_KEY=
SEARCHAD_SECRET_KEY=
SEARCHAD_CUSTOMER_ID=
SESSION_SECRET=
# 회원 가명처리용 별도 키(미설정 시 SESSION_SECRET에서 HKDF로 분리 파생). 세션 키와 분리 권장.
IDENTITY_SECRET=
# 신뢰하는 프록시 홉 수. Render 등 단일 프록시=1, 직접 노출=0. 미설정 시 운영은 1로 동작.
TRUST_PROXY_HOPS=1
